/* test class declaration checking */

class B () extends A () {		/* error: A not declared yet */
  method g () -> bool { return true; }
  method h (x : int, y : int) -> A { return self; }
}

class A () {
  method f () -> void { return; }
}

class main () {  // to keep the main check happy
  method run () -> void { return; }
}
