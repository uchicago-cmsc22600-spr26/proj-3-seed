/* this program just tests interface checking */

interface A {
  method f () -> void
}

interface B extends A {
  method g () -> bool
  method h (int,  int) -> A
}

interface A {  /* error: redeclaration of A */
  method f () -> void
}

class main () {  // to keep the main check happy
  method run () -> void { return; }
}
