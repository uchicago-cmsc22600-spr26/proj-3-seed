/* test optional member-function selection */
class A () {
  var x : A? = A.nil
  method init () -> void { self.x = self; }
  method getX () -> A? { return self.x; }
}

class main () {
  method pr (x : A?) -> void {
    if (x == A.nil) {
      system.print("nil");
    }
    else {
      system.print("A");
    }
  }
  method run () -> void {
    var a = A();
    system.print("a.getX()?getX() = "); self.pr(a.getX()?getX()); system.print ("\n");
    a.init();
    system.print("a.getX()?getX() = "); self.pr(a.getX()?getX()); system.print ("\n");
  }
}
