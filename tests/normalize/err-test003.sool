/* test that required function selection signals an error on nil */

class A () {
  method print () -> void { system.print ("hello\n"); }
}
class B () {
  method get () -> A? { return A.nil; }
}
class main () {
  var b : B = B()
  method run () -> void {
    self.b.get()!print();  // should fail
  }
}
