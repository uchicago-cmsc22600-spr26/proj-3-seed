PROGRAM
  [
    DCL_Class
      main
      [ ]
      <none>
      [ ]
      [
        MDCL
          run
          [ ]
          TY_Void
          BLK
            [ ]
        MDCL
          foo
          [
            PARAM
              b
              TY_Bool
          ]
          TY_Void
          BLK
            [
              STM_If
                [
                  EXP_Var(b)
                  BLK
                    [
                      STM_Call
                        EXP_Apply
                          MEMB
                            EXP_Var(system)
                            DOT
                            print
                          [
                            EXP_String("ok")
                          ]
                    ]
                ]
                <none>
            ]
        MDCL
          bar
          [
            PARAM
              b
              TY_Bool
          ]
          TY_Void
          BLK
            [
              STM_If
                [
                  EXP_Var(b)
                  BLK
                    [
                      STM_Call
                        EXP_Apply
                          MEMB
                            EXP_Var(system)
                            DOT
                            print
                          [
                            EXP_String("ok")
                          ]
                    ]
                ]
                BLK
                  [
                    STM_Call
                      EXP_Apply
                        MEMB
                          EXP_Var(system)
                          DOT
                          print
                        [
                          EXP_String("fail\n")
                        ]
                  ]
            ]
        MDCL
          bar
          [
            PARAM
              b1
              TY_Bool
            PARAM
              b2
              TY_Bool
          ]
          TY_Void
          BLK
            [
              STM_If
                [
                  EXP_Andalso
                    EXP_Var(b1)
                    EXP_Var(b2)
                  BLK
                    [
                      STM_Call
                        EXP_Apply
                          MEMB
                            EXP_Var(system)
                            DOT
                            print
                          [
                            EXP_String("ok/ok")
                          ]
                    ]
                  EXP_Var(b1)
                  BLK
                    [
                      STM_Call
                        EXP_Apply
                          MEMB
                            EXP_Var(system)
                            DOT
                            print
                          [
                            EXP_String("ok/fail")
                          ]
                    ]
                  EXP_Var(b2)
                  BLK
                    [
                      STM_Call
                        EXP_Apply
                          MEMB
                            EXP_Var(system)
                            DOT
                            print
                          [
                            EXP_String("fail/ok")
                          ]
                    ]
                ]
                BLK
                  [
                    STM_Call
                      EXP_Apply
                        MEMB
                          EXP_Var(system)
                          DOT
                          print
                        [
                          EXP_String("fail/fail\n")
                        ]
                  ]
            ]
      ]
  ]
