// test05.sool

class main () {
  method print (prefix : string, arg : toStringI) -> void {
    system.print(msg @ arg.toString() @ "\n");
  }
  method run () -> void {
    /* associativity and precedence tests */
    print ("1+2+3", 1+2+3);
    print ("1+2-3", 1+2-3);
    print ("1-2+3", 1-2+3);
    print ("1-2-3", 1-2-3);
    print ("1+(2+3)", 1+(2+3));
    print ("1-(2-3)", 1-(2-3));
    print ("1*2*3", 1*2*3);
    print ("1/2/3", 1/2/3);
    print ("1+2*3+4", 1+2*3+4);
    print ("1-2*3+4", 1-2*3+4);
    print ("1*2+3", 1*2+3);
    print ("int.nil ?? 42 ?? 17", int.nil ?? 42 ?? 17);
    print ("true && true && true", true && true && true);
    print ("false || false || true", false || false || true);
    print ("true && false || true", true && false || true);
    print ("1 < 2 && 2 < 3", 1 < 2 && 2 < 3);
    print ("1 <= 2 && 2 <= 3", 1 <= 2 && 2 <= 3);
    print ("1 == 2 || 2 != 3", 1 == 2 || 2 != 3);
    print ("1 == 2 == false", 1 == 2 == false);
  }
}
